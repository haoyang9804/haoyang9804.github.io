---
import "katex/dist/katex.min.css";
import "../styles/global.css";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION
} = Astro.props;

const pageTitle = title === SITE_TITLE ? SITE_TITLE : `${title} - ${SITE_TITLE}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta
      name="google-site-verification"
      content="q8DtGMRIbR6QaJVsuBq_ia7dVYog6Z1o9Lwm4-AZP-w"
    />
    <link rel="icon" href="/Erwin_icon.png" />
    <link rel="alternate" type="application/rss+xml" title="Haoyang Ma Blog" href="/rss.xml" />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600&family=Noto+Sans+SC:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="main-container">
      <slot />
    </main>
    <div id="visit-stats" class="visit-stats" hidden aria-hidden="true">
      <div class="visit-stat">
        <span>全站浏览量</span>
        <strong id="busuanzi_site_pv">...</strong>
      </div>
      <div class="visit-stat">
        <span>本页浏览量</span>
        <strong id="busuanzi_page_pv">...</strong>
      </div>
    </div>
    <script>
      (() => {
        const currentUrl = new URL(window.location.href);
        const showStats = currentUrl.searchParams.get("stats") === "1";
        const statsPanel = document.querySelector("#visit-stats");

        if (showStats && statsPanel instanceof HTMLElement) {
          statsPanel.hidden = false;
          statsPanel.setAttribute("aria-hidden", "false");
        }

        currentUrl.search = "";
        currentUrl.hash = "";

        fetch("https://cdn.busuanzi.cc/api.php", {
          method: "POST",
          body: JSON.stringify({
            url: currentUrl.href,
            referrer: document.referrer
          })
        })
          .then((response) => response.json())
          .then((stats) => {
            for (const key in stats) {
              document.querySelectorAll(`#${key}`).forEach((element) => {
                element.textContent = stats[key];
              });
            }
          })
          .catch((error) => console.error(error));
      })();
    </script>
  </body>
</html>
